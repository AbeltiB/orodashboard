// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Region {
  ADDIS_ABABA
  OROMIA
  AMHARA
  TIGRAY
  SNNPR
  AFAR
  SOMALI
  BENISHANGUL_GUMUZ
  GAMBELA
  HARARI
  DIRE_DAWA
  SIDAMA
}

enum RoadType {
  ASPHALT
  GRAVEL
  MIXED
}

enum EmployeeRole {
  SUPERVISOR
  TICKETER
  CASHIER
}

enum Sex {
  MALE
  FEMALE
}

enum PosStatus {
  ACTIVE
  IDLE
  MAINTENANCE
  DECOMMISSIONED
}

enum DeliveryMethod {
  BANK_TRANSFER
  CHEQUE
  TELEBIRR
  OTHER
}

enum BusType {
  BUS
  MIDBUS
  MINIBUS
}

enum BusLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

enum PosAssignmentMode {
  EXCLUSIVE // one employee has custody of the machine (default, existing behavior)
  SHARED    // station-level hardware, rotates between employees by shift — see PosSession
}

enum ShiftType {
  MORNING
  AFTERNOON
}

// ─────────────────────────────────────────────────────────────────────────────
// STATION
// ─────────────────────────────────────────────────────────────────────────────

model Station {
  id        String   @id @default(cuid())
  code      String   @unique // e.g. "STN-001" — human-readable code
  name      String
  region    Region
  location  String   // street / landmark description

  zoneId    String?
  zone      Zone?    @relation(fields: [zoneId], references: [id])

  // Soft delete
  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  terminalsAsOrigin  Terminal[] @relation("OriginStation")
  terminalsAsTarget  Terminal[] @relation("TargetStation")
  employees          Employee[]
  posMachines        PosMachine[]
  posMachineHistory  PosMachineHistory[]
  posSessions        PosSession[]
  shiftAssignments   ShiftAssignment[]

  @@index([isDeleted])
  @@index([region])
  @@index([zoneId])
  @@map("stations")
}

// ─────────────────────────────────────────────────────────────────────────────
// ZONE  (groups stations within a region; has its own supervisor(s))
// ─────────────────────────────────────────────────────────────────────────────

model Zone {
  id          String    @id @default(cuid())
  region      Region
  name        String
  description String?

  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  stations    Station[]
  supervisors ZoneSupervisor[]

  @@unique([region, name])
  @@index([isDeleted])
  @@map("zones")
}

model ZoneSupervisor {
  id         String   @id @default(cuid())

  zoneId     String
  zone       Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  assignedAt DateTime @default(now())

  @@unique([zoneId, employeeId])
  @@index([employeeId])
  @@map("zone_supervisors")
}

// ─────────────────────────────────────────────────────────────────────────────
// TERMINAL
// ─────────────────────────────────────────────────────────────────────────────

model Terminal {
  id               String   @id @default(cuid())

  stationId        String
  station          Station  @relation("OriginStation", fields: [stationId], references: [id])

  name             String

  isLinkedStation  Boolean  @default(false)
  linkedStationId  String?
  linkedStation    Station? @relation("TargetStation", fields: [linkedStationId], references: [id])

  isDeparture      Boolean  @default(false)
  isArrival        Boolean  @default(true)

  distanceKm       Decimal  @db.Decimal(8, 2)
  roadType         RoadType

  asphaltKm        Decimal? @db.Decimal(8, 2)
  gravelKm         Decimal? @db.Decimal(8, 2)

  isDeleted        Boolean  @default(false)
  deletedAt        DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([stationId, isDeleted])
  @@index([linkedStationId])
  @@map("terminals")
}

// ─────────────────────────────────────────────────────────────────────────────
// EMPLOYEE
// ─────────────────────────────────────────────────────────────────────────────

model Employee {
  id             String      @id @default(cuid())
  code           String      @unique // e.g. "EMP-001"

  firstName      String
  middleName     String?
  lastName       String

  phone          String      @unique
  email          String?     @unique

  posPassword    String?

  // Fayda Alias Number — 16 digits stored without dashes
  fan            String?     @unique @db.Char(16)

  stationId      String?
  station        Station?    @relation(fields: [stationId], references: [id])

  basicSalary    Decimal     @db.Decimal(10, 2)
  role           EmployeeRole
  accountNumber  String?
  employmentDate DateTime?   @db.Date
  sex            Sex

  isDeleted      Boolean     @default(false)
  deletedAt      DateTime?

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  posMachines         PosMachine[]
  posMachineHistory   PosMachineHistory[]
  pettyCash           PettyCash[]
  zoneSupervisorOf    ZoneSupervisor[]
  posSessions         PosSession[]
  shiftAssignments    ShiftAssignment[]

  @@index([stationId, isDeleted])
  @@index([role])
  @@index([isDeleted])
  @@map("employees")
}

// ─────────────────────────────────────────────────────────────────────────────
// PETTY CASH
// ─────────────────────────────────────────────────────────────────────────────

model PettyCash {
  id          String         @id @default(cuid())

  employeeId  String
  employee    Employee       @relation(fields: [employeeId], references: [id])

  amount      Decimal        @db.Decimal(10, 2)
  date        DateTime       @db.Date
  method      DeliveryMethod
  reference   String
  note        String?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([employeeId])
  @@index([date])
  @@map("petty_cash")
}

// ─────────────────────────────────────────────────────────────────────────────
// POS MACHINE
// ─────────────────────────────────────────────────────────────────────────────

model PosMachine {
  id                 String    @id @default(cuid())
  code               String    @unique // e.g. "POS-001"

  make               String
  model              String
  serial             String    @unique
  status             PosStatus @default(ACTIVE)
  appVersion         String
  remark             String?

  // EXCLUSIVE: employeeId below is the current owner (existing behavior).
  // SHARED: employeeId stays null — "who's on it now" is derived from the
  // PosSession with endedAt = null for this machine instead.
  assignmentMode     PosAssignmentMode @default(EXCLUSIVE)

  stationId          String?
  station            Station?  @relation(fields: [stationId], references: [id])

  employeeId         String?
  employee           Employee? @relation(fields: [employeeId], references: [id])

  isDeleted          Boolean   @default(false)
  deletedAt          DateTime?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  history            PosMachineHistory[]
  sessions           PosSession[]
  shiftAssignments   ShiftAssignment[]

  @@index([stationId])
  @@index([employeeId])
  @@index([status, isDeleted])
  @@map("pos_machines")
}

// ─────────────────────────────────────────────────────────────────────────────
// POS SESSION  (manual usage log for SHARED-mode machines — see note on
// PosMachine.assignmentMode. There is no integration with the actual POS
// ticketing app; this is maintained inside OroDashboard only.)
// ─────────────────────────────────────────────────────────────────────────────

model PosSession {
  id           String     @id @default(cuid())

  posMachineId String
  posMachine   PosMachine @relation(fields: [posMachineId], references: [id])

  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id])
  employeeName String     // snapshot at session start — same precedent as PosMachineHistory

  stationId    String?
  station      Station?   @relation(fields: [stationId], references: [id])
  stationName  String?

  startedAt    DateTime   @default(now())
  endedAt      DateTime?  // null = currently active (at most one open session per machine, enforced transactionally)

  note         String?
  loggedBy     String?    // AdminUser id — accountability for a manually-entered log

  // Optional link to the scheduled shift this session was worked under. Not
  // unique — a shift could plausibly span more than one session.
  shiftAssignmentId String?
  shiftAssignment   ShiftAssignment? @relation(fields: [shiftAssignmentId], references: [id])

  @@index([posMachineId, endedAt])
  @@index([employeeId])
  @@index([stationId])
  @@index([shiftAssignmentId])
  @@map("pos_sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// POS MACHINE HISTORY
// ─────────────────────────────────────────────────────────────────────────────

model PosMachineHistory {
  id           String     @id @default(cuid())

  posMachineId String
  posMachine   PosMachine @relation(fields: [posMachineId], references: [id])

  employeeId   String?
  employee     Employee?  @relation(fields: [employeeId], references: [id])
  employeeName String?

  stationId    String?
  station      Station?   @relation(fields: [stationId], references: [id])
  stationName  String?

  fromDate     DateTime   @db.Date
  toDate       DateTime?  @db.Date

  remark       String?

  createdAt    DateTime   @default(now())

  @@index([posMachineId])
  @@index([employeeId])
  @@index([toDate])
  @@map("pos_machine_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// SHIFT SCHEDULE  (weekly schedule is generated by an external scheduler
// system; OroDashboard doesn't generate it — it imports and displays it)
// ─────────────────────────────────────────────────────────────────────────────

model ShiftAssignment {
  id            String       @id @default(cuid())

  employeeId    String
  employee      Employee     @relation(fields: [employeeId], references: [id])

  stationId     String
  station       Station      @relation(fields: [stationId], references: [id])

  date          DateTime     @db.Date
  shiftType     ShiftType

  // Role the employee is covering for this shift — not necessarily their
  // primary Employee.role (e.g. a supervisor filling in as a ticketer).
  role          EmployeeRole

  posMachineId  String?
  posMachine    PosMachine?  @relation(fields: [posMachineId], references: [id])

  source        String       @default("manual") // "manual" | "import"
  externalRef   String?      // scheduler's own id — traceability only, not the dedup key

  importBatchId String?
  importBatch   ShiftImportBatch? @relation(fields: [importBatchId], references: [id])

  posSessions   PosSession[]

  isDeleted     Boolean      @default(false)
  deletedAt     DateTime?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([employeeId, date, shiftType])
  @@index([stationId, date])
  @@index([date, shiftType])
  @@index([posMachineId])
  @@index([importBatchId])
  @@map("shift_assignments")
}

model ShiftImportBatch {
  id           String   @id @default(cuid())

  fileName     String
  importedBy   String   // AdminUser id

  rowCount     Int
  successCount Int
  errorCount   Int
  errors       Json?    // [{ row, message }]

  createdAt    DateTime @default(now())

  assignments  ShiftAssignment[]

  @@map("shift_import_batches")
}

// ─────────────────────────────────────────────────────────────────────────────
// FARE PRICE MATRIX
// ─────────────────────────────────────────────────────────────────────────────

model FareMatrix {
  id           String   @id @default(cuid())

  busType      BusType
  busLevel     BusLevel

  asphaltRate  Decimal  @db.Decimal(8, 4)
  gravelRate   Decimal  @db.Decimal(8, 4)

  updatedBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([busType, busLevel])
  @@index([busType])
  @@map("fare_matrix")
}

// ─────────────────────────────────────────────────────────────────────────────
// SYSTEM CONFIG  (key-value store for settings)
// ─────────────────────────────────────────────────────────────────────────────

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}

// ─────────────────────────────────────────────────────────────────────────────
// ADMIN USER
// ─────────────────────────────────────────────────────────────────────────────

model AdminUser {
  id            String    @id @default(cuid())

  firstName     String
  middleName    String?
  lastName      String

  phone         String    @unique // +251XXXXXXXXX — login identifier
  companyEmail  String?
  personalEmail String?

  role          AdminRole @default(ADMIN)
  isActive      Boolean   @default(true)

  // Per-page permissions — [{ page, canView, canEdit }], validated at the API boundary
  permissions   Json      @default("[]")

  // OTP (hashed via bcrypt — see src/lib/pin.ts — never store the raw code)
  otpCodeHash    String?
  otpExpiresAt   DateTime?
  otpAttempts    Int       @default(0)
  otpRequestedAt DateTime? // for resend rate-limiting

  // Lockout after repeated failed OTP attempts
  lockedUntil    DateTime?

  lastLoginAt    DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sessions       Session[]

  @@index([role])
  @@index([isActive])
  @@map("admin_users")
}

model Session {
  id          String    @id @default(cuid())

  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  tokenHash   String    @unique // sha256(rawToken) — raw token only ever lives in the cookie
  expiresAt   DateTime            // createdAt + 7 days, fixed — never slides
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime  @default(now())

  userAgent   String?
  ipAddress   String?

  revokedAt   DateTime? // set on logout / admin deactivation; NULL = still valid

  @@index([adminUserId])
  @@index([expiresAt])
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// SALES  (mirrored from the external OTA ticketing system — see
// src/lib/ota/*. OroDashboard doesn't originate this data, it periodically
// pulls and mirrors it so it can be viewed/filtered here instead of the
// source system's own dashboard.)
// ─────────────────────────────────────────────────────────────────────────────

enum SyncSource {
  MANUAL
  AUTO
}

enum SyncStatus {
  SUCCESS
  FAILED
  PARTIAL
}

model SalesTrip {
  // OTA's own trip id — used directly as our primary key so upserts are a
  // natural dedupe, no separate surrogate key needed.
  id                     String   @id
  date                   DateTime
  distanceKm             Decimal  @db.Decimal(10, 2)
  tariff                 Decimal  @db.Decimal(10, 2)
  serviceCharge          Decimal  @db.Decimal(10, 2)
  passengers             Int
  level                  String

  companyId              String
  companyName            String

  departureTerminalName  String
  arrivalTerminalName    String

  employeeExternalId     String?
  employeeName           String?
  employeeEmail          String?

  vehicleExternalId      String?
  vehiclePlateNo         String?
  vehiclePlateCode       String?
  vehicleFleetCategory   String?
  vehicleAssociation     String?
  vehicleLevel           String?

  lastSyncId             String?
  lastSync               SalesSyncLog? @relation(fields: [lastSyncId], references: [id])

  firstSeenAt            DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([date])
  @@index([departureTerminalName])
  @@index([arrivalTerminalName])
  @@index([employeeExternalId])
  @@index([vehicleExternalId])
  @@index([lastSyncId])
  @@map("sales_trips")
}

model SalesSyncLog {
  id            String     @id @default(cuid())

  source        SyncSource
  triggeredBy   String?    // AdminUser id when source = MANUAL, null for AUTO

  windowFrom    DateTime?  // null = full backfill (no lower bound)
  windowTo      DateTime

  status        SyncStatus @default(SUCCESS)
  pagesFetched  Int        @default(0)
  rowsFetched   Int        @default(0)
  rowsCreated   Int        @default(0)
  rowsUpdated   Int        @default(0)
  errorMessage  String?

  startedAt     DateTime   @default(now())
  finishedAt    DateTime?

  trips         SalesTrip[]

  @@index([source])
  @@index([startedAt])
  @@map("sales_sync_logs")
}
