// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Region {
  ADDIS_ABABA
  OROMIA
  AMHARA
  TIGRAY
  SNNPR
  AFAR
  SOMALI
  BENISHANGUL_GUMUZ
  GAMBELA
  HARARI
  DIRE_DAWA
  SIDAMA
}

enum RoadType {
  ASPHALT
  GRAVEL
  MIXED
}

enum EmployeeRole {
  SUPERVISOR
  TICKETER
  CASHIER
}

enum Sex {
  MALE
  FEMALE
}

enum PosStatus {
  ACTIVE
  IDLE
  MAINTENANCE
  DECOMMISSIONED
}

enum DeliveryMethod {
  BANK_TRANSFER
  CHEQUE
  TELEBIRR
  OTHER
}

enum BusType {
  BUS
  MIDBUS
  MINIBUS
}

enum BusLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

// ─────────────────────────────────────────────────────────────────────────────
// STATION
// ─────────────────────────────────────────────────────────────────────────────

model Station {
  id        String   @id @default(cuid())
  code      String   @unique // e.g. "STN-001" — human-readable code
  name      String
  region    Region
  zone      String
  location  String   // street / landmark description

  // Soft delete
  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  terminalsAsOrigin  Terminal[] @relation("OriginStation")
  terminalsAsTarget  Terminal[] @relation("TargetStation")
  employees          Employee[]
  posMachines        PosMachine[]
  posMachineHistory  PosMachineHistory[]

  @@index([isDeleted])
  @@index([region])
  @@map("stations")
}

// ─────────────────────────────────────────────────────────────────────────────
// TERMINAL
// ─────────────────────────────────────────────────────────────────────────────

model Terminal {
  id               String   @id @default(cuid())

  stationId        String
  station          Station  @relation("OriginStation", fields: [stationId], references: [id])

  name             String

  isLinkedStation  Boolean  @default(false)
  linkedStationId  String?
  linkedStation    Station? @relation("TargetStation", fields: [linkedStationId], references: [id])

  isDeparture      Boolean  @default(false)
  isArrival        Boolean  @default(true)

  distanceKm       Decimal  @db.Decimal(8, 2)
  roadType         RoadType

  asphaltKm        Decimal? @db.Decimal(8, 2)
  gravelKm         Decimal? @db.Decimal(8, 2)

  isDeleted        Boolean  @default(false)
  deletedAt        DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([stationId, isDeleted])
  @@index([linkedStationId])
  @@map("terminals")
}

// ─────────────────────────────────────────────────────────────────────────────
// EMPLOYEE
// ─────────────────────────────────────────────────────────────────────────────

model Employee {
  id             String      @id @default(cuid())
  code           String      @unique // e.g. "EMP-001"

  firstName      String
  middleName     String?
  lastName       String

  phone          String      @unique
  email          String?     @unique

  posPassword    String?

  // Fayda Alias Number — 16 digits stored without dashes
  fan            String?     @unique @db.Char(16)

  stationId      String?
  station        Station?    @relation(fields: [stationId], references: [id])

  basicSalary    Decimal     @db.Decimal(10, 2)
  role           EmployeeRole
  accountNumber  String?
  employmentDate DateTime?   @db.Date
  sex            Sex

  isDeleted      Boolean     @default(false)
  deletedAt      DateTime?

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  posMachines         PosMachine[]
  posMachineHistory   PosMachineHistory[]
  pettyCash           PettyCash[]

  @@index([stationId, isDeleted])
  @@index([role])
  @@index([isDeleted])
  @@map("employees")
}

// ─────────────────────────────────────────────────────────────────────────────
// PETTY CASH
// ─────────────────────────────────────────────────────────────────────────────

model PettyCash {
  id          String         @id @default(cuid())

  employeeId  String
  employee    Employee       @relation(fields: [employeeId], references: [id])

  amount      Decimal        @db.Decimal(10, 2)
  date        DateTime       @db.Date
  method      DeliveryMethod
  reference   String
  note        String?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([employeeId])
  @@index([date])
  @@map("petty_cash")
}

// ─────────────────────────────────────────────────────────────────────────────
// POS MACHINE
// ─────────────────────────────────────────────────────────────────────────────

model PosMachine {
  id                 String    @id @default(cuid())
  code               String    @unique // e.g. "POS-001"

  make               String
  model              String
  serial             String    @unique
  status             PosStatus @default(ACTIVE)
  appVersion         String
  remark             String?

  stationId          String?
  station            Station?  @relation(fields: [stationId], references: [id])

  employeeId         String?
  employee           Employee? @relation(fields: [employeeId], references: [id])

  isDeleted          Boolean   @default(false)
  deletedAt          DateTime?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  history            PosMachineHistory[]

  @@index([stationId])
  @@index([employeeId])
  @@index([status, isDeleted])
  @@map("pos_machines")
}

// ─────────────────────────────────────────────────────────────────────────────
// POS MACHINE HISTORY
// ─────────────────────────────────────────────────────────────────────────────

model PosMachineHistory {
  id           String     @id @default(cuid())

  posMachineId String
  posMachine   PosMachine @relation(fields: [posMachineId], references: [id])

  employeeId   String?
  employee     Employee?  @relation(fields: [employeeId], references: [id])
  employeeName String?

  stationId    String?
  station      Station?   @relation(fields: [stationId], references: [id])
  stationName  String?

  fromDate     DateTime   @db.Date
  toDate       DateTime?  @db.Date

  remark       String?

  createdAt    DateTime   @default(now())

  @@index([posMachineId])
  @@index([employeeId])
  @@index([toDate])
  @@map("pos_machine_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// FARE PRICE MATRIX
// ─────────────────────────────────────────────────────────────────────────────

model FareMatrix {
  id           String   @id @default(cuid())

  busType      BusType
  busLevel     BusLevel

  asphaltRate  Decimal  @db.Decimal(8, 4)
  gravelRate   Decimal  @db.Decimal(8, 4)

  updatedBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([busType, busLevel])
  @@index([busType])
  @@map("fare_matrix")
}

// ─────────────────────────────────────────────────────────────────────────────
// SYSTEM CONFIG  (key-value store for settings)
// ─────────────────────────────────────────────────────────────────────────────

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}

// ─────────────────────────────────────────────────────────────────────────────
// ADMIN USER
// ─────────────────────────────────────────────────────────────────────────────

model AdminUser {
  id            String    @id @default(cuid())

  firstName     String
  middleName    String?
  lastName      String

  phone         String    @unique // +251XXXXXXXXX — login identifier
  companyEmail  String?
  personalEmail String?

  role          AdminRole @default(ADMIN)
  isActive      Boolean   @default(true)

  // Per-page permissions — [{ page, canView, canEdit }], validated at the API boundary
  permissions   Json      @default("[]")

  // OTP (hashed via bcrypt — see src/lib/pin.ts — never store the raw code)
  otpCodeHash    String?
  otpExpiresAt   DateTime?
  otpAttempts    Int       @default(0)
  otpRequestedAt DateTime? // for resend rate-limiting

  // Lockout after repeated failed OTP attempts
  lockedUntil    DateTime?

  lastLoginAt    DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sessions       Session[]

  @@index([role])
  @@index([isActive])
  @@map("admin_users")
}

model Session {
  id          String    @id @default(cuid())

  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  tokenHash   String    @unique // sha256(rawToken) — raw token only ever lives in the cookie
  expiresAt   DateTime            // createdAt + 7 days, fixed — never slides
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime  @default(now())

  userAgent   String?
  ipAddress   String?

  revokedAt   DateTime? // set on logout / admin deactivation; NULL = still valid

  @@index([adminUserId])
  @@index([expiresAt])
  @@map("sessions")
}
