DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Pre-seeded super admin — created idempotently at server boot if no admin
# with this phone number exists yet. Safe to change later via the dashboard;
# these env vars only matter for the very first boot.
SUPER_ADMIN_PHONE="+251900000000"
SUPER_ADMIN_FIRST_NAME="First"
SUPER_ADMIN_MIDDLE_NAME="Middle"
SUPER_ADMIN_LAST_NAME="Last"

# OTA (company.ota.gov.et) sales-report source system — credentials for the
# read-only company-user login used to pull the trips report.
OTA_BASE_URL="https://company.ota.gov.et"
OTA_EMAIL="user@example.com"
OTA_PASSWORD="changeme"
OTA_COMPANY_ID="00000000-0000-0000-0000-000000000000"

# Shared secret an external cron trigger presents to POST /api/sales/sync
# instead of an admin session.
SALES_SYNC_TOKEN="change-me-to-a-long-random-value"

# Optional override for the OTP SMS provider endpoint. Defaults to
# https://bstechsms.vercel.app/api/sms if unset.
SMS_API_URL="https://bstechsms.vercel.app/api/sms"
